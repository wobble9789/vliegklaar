{
  "name": "vliegklaar",
  "version": "1.0.0",
  "private": true,
  "description": "Zorgeloos reizen met persoonlijke begeleiding",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "echo '\n⚠️  Voor E2E tests in Codespaces:\n1. Zorg dat dev server draait: npm run dev\n2. Kopieer de URL uit de browser (bijv. https://xxx.app.github.dev)\n3. Run: PLAYWRIGHT_TEST_BASE_URL=https://jouw-url.app.github.dev npm run test:e2e:chromium\n' && echo 'Installeer eerst dependencies met: bash scripts/install-playwright-deps.sh\n'",
    "test:e2e:chromium": "npx playwright install chromium && npx playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run lint && npm run test:coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
